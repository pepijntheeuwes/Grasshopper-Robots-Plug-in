, 75, 75, 75, 75, 75, 75, 75, 75, 75, 75, 75, 77, 77, 77, 77, 77, 77, 77, 77, 76, 76, 76, 76, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 79, 79, 79, 79, 74, 74, 74, 74, 69, 69, 69, 69, 63, 63, 63, 63, 56, 56, 56, 56, 53, 53, 53, 53, 47, 47, 47, 47, 43, 43, 43, 43, 40, 40, 40, 40, 33, 33, 33, 33, 33, 33, 33, 33, 33, 33, 33, 33, 34, 34, 34, 34, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 35, 36, 36, 36, 36, 36, 36, 36, 36, 36, 36, 36, 36, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 37, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 37, 37, 37, 37, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 39, 40, 40, 40, 40, 40, 40, 40, 40, 40, 40, 40, 40, 41, 41, 41, 41, 42, 42, 42, 42, 42, 42, 42, 42, 41, 41, 41, 41, 41, 41, 41, 41, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 42, 44, 44, 44, 44, 44, 44, 44, 44, 44, 44, 44, 44, 43, 43, 43, 43, 44, 44, 44, 44, 44, 44, 44, 44, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 45, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 46, 47, 47, 47, 47, 47, 47, 47, 47, 46, 46, 46, 46, 48, 48, 48, 48, 48, 48, 48, 48, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 49, 51, 51, 51, 51, 51, 51, 51, 51, 50, 50, 50, 50, 52, 52, 52, 52, 52, 52, 52, 52, 50, 50, 50, 50, 52, 52, 52, 52, 52, 52, 52, 52, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 55, 55, 55, 55, 55, 55, 55, 55, 54, 54, 54, 54, 56, 56, 56, 56, 56, 56, 56, 56, 55, 55, 55, 55, 56, 56, 56, 56, 56, 56, 56, 56, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 58, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 58, 58, 58, 58, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 59, 56, 56, 56, 56, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 56, 56, 56, 56, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 57, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 54, 54, 54, 54, 56, 56, 56, 56, 56, 56, 56, 56, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 54, 54, 54, 54, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 55, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 53, 53, 53, 53, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 53, 53, 53, 53, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 53, 53, 53, 53, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 53, 53, 53, 53, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 54, 52, 52, 52, 52, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 53, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 51, 51, 51, 51, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 52, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 45, 45, 45, 45, 38, 38, 38, 38, 34, 34, 34, 34, 26, 26, 26, 26, 23, 23, 23, 23, 19, 19, 19, 19, 16, 16, 16, 16, 14, 14, 14, 14, 12, 12, 12, 12, 10, 10, 10, 10, 8, 8, 8, 8, 7, 7, 7, 7, 6, 6, 6, 6, 6, 6, 6, 6, 5, 5, 5, 5, 4, 4, 4, 4, 4, 4, 4, 4]
    global g = 1000
    global lt = 0.06
    global time = 0.14400000000000002

    global extrusion_trigger = False
    global thread_val_E = 0
    global thread_val_F = 0 
    global target_pose = [0,0,0,0,0,0]
    global raw_data = [0,0,0,0,0,0,0,0,0]

    def fetch_next_pose():
        socket_send_string("NEXT", "laptop_socket")
        # We now expect 8 floats: [jointpose, height, distance]
        data = socket_read_ascii_float(8, "laptop_socket")
        textmsg("laptop data = ",data)
        return data
    end

    raw_data = fetch_next_pose()
    if raw_data[0] < 8:
        popup("Error: Could not fetch initial waypoint", "Error", error=True)
        halt
    end

    thread ExtruderControl():
        while True:
            if extrusion_trigger == True:
                socket_send_string("G1 E", "duet_socket")
                socket_send_string(thread_val_E, "duet_socket")
                socket_send_string(" F", "duet_socket")
                socket_send_string(thread_val_F, "duet_socket")
                socket_send_byte(10, "duet_socket")
                extrusion_trigger = False
            end
            sync()
        end
    end

    ext_thread_handle = run ExtruderControl()
    
    # Heating
    popup("For Heating and Priming Nozzle press CONTINUE.", "Set up hotend", blocking=True)
    socket_send_line("T0", "duet_socket")  
    socket_send_line("M109 S200", "duet_socket")
    socket_send_line("G1 E30 F300", "duet_socket")
    sleep(3)
    
    layer_idx = 0
    pose_pointer = 0
    num_layers = length(poses_per_layer)

    target_pose = [raw_data[1], raw_data[2], raw_data[3], raw_data[4], raw_data[5], raw_data[6]]

    popup("If Nozzle is primed press CONTINUE to move to the start position", "Start", blocking=True)
    movej(target_pose, a=1.0, v=0.1)

    keep_printing = True
    while keep_printing:
        while layer_idx < num_layers:
            poses_in_this_layer = poses_per_layer[layer_idx]
            i = 0

            while i < poses_in_this_layer:
                raw_data = fetch_next_pose()
                if raw_data[0] >= 6:
                    target_pose = [raw_data[1], raw_data[2], raw_data[3], raw_data[4], raw_data[5], raw_data[6]]
                    h = raw_data[7]
                    dist = raw_data[8]
                                       
                    thread_val_E = 0.08*((0.35 * h * dist)/0.126)
                    thread_val_F = (thread_val_E / time) * 60
                    extrusion_trigger = True

                    # Execute real-time motion
                    servoj(target_pose, t=time, lookahead_time=lt, gain=g)
                else:
                    textmsg("Warning: Failed to receive pose at pointer ", pose_pointer)
                    sync()
                end

                pose_pointer = pose_pointer + 1
                i = i + 1
                sync()
            end
            layer_idx = layer_idx + 1
            sync()
        end 
        keep_printing = False
    end

    kill ext_thread_handle 
    # Turn off heaters
    socket_send_line("T0", "duet_socket")  
    socket_send_line("M104 S0", "duet_socket")
    # socket_send_byte(10, "duet_socket")
    movej([1.57, -1.57, 1.57, 0, 1.57, 0], a=1, v=0.3, r=0)
    textmsg("Program finished and thread killed -> turn off hotend.")
    socket_close("duet_socket")
end
extrusion_program()
    