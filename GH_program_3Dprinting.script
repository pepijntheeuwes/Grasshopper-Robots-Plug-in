def extrusion_program():
    socket_open("172.19.126.244", 3000, "laptop_socket")
    socket_open("172.19.126.242", 23, "duet_socket")
    sleep(1.5)
    set_tcp(p[0, -0.096, 0.055, 0, -1.5708, 0])
